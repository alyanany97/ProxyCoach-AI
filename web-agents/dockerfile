FROM node:20 AS deps
WORKDIR /app

# Copy package files and prisma schema first
COPY package*.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./

# Install dependencies
RUN npm install --legacy-peer-deps

# Generate Prisma Client (outputs to ./src/generated/prisma per schema.prisma)
RUN DATABASE_URL="postgresql://user:pass@localhost:5432/db" npx prisma generate

FROM node:20 AS builder
WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy Prisma files
COPY --from=deps /app/prisma ./prisma
COPY --from=deps /app/prisma.config.ts ./

# Copy source code and config files needed for build
COPY package*.json ./
COPY tsconfig.json ./
COPY next.config.ts ./
COPY postcss.config.js ./
COPY tailwind.config.ts ./
COPY src ./src
# Restore Prisma client from deps (COPY src overwrote local tree; generate output lives under src/generated)
COPY --from=deps /app/src/generated ./src/generated
COPY public ./public

# Build Next.js app
ENV NEXT_TELEMETRY_DISABLED=1
# Verify Tailwind and PostCSS configs are present
RUN test -f postcss.config.js && test -f tailwind.config.ts && echo "Config files found" || (echo "ERROR: Config files missing" && exit 1)
# Verify source files are present and list some component files to ensure they're accessible
RUN test -f src/app/globals.css && echo "globals.css found" || (echo "ERROR: globals.css missing" && exit 1)
RUN find src -name "*.tsx" -type f | head -5 | xargs ls -lh || echo "Source files check"
# Clear any existing build cache and build
RUN rm -rf .next && npm run build
# Verify CSS was generated and check its size/content
RUN find .next/static -name "*.css" -exec sh -c 'echo "CSS file: $1, Size: $(wc -c < "$1") bytes, First 200 chars: $(head -c 200 "$1")"' _ {} \; || echo "WARNING: No CSS files found in .next/static"

FROM node:20 AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

# Copy necessary runtime assets
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/package-lock.json ./package-lock.json
COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=deps /app/prisma ./prisma
COPY --from=deps /app/prisma.config.ts ./
COPY --from=builder /app/src/generated ./src/generated

# Verify package.json exists and we're in the right directory
RUN pwd && ls -la && test -f package.json || (echo "ERROR: package.json not found in $(pwd)" && exit 1)

EXPOSE 3000
# Use shell form to ensure proper path resolution
CMD cd /app && npm start