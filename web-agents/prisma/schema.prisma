generator client {
   provider   = "prisma-client"
   output     = "../generated/prisma"
   engineType = "client"
}

datasource db {
   provider = "postgresql"
}

// Conversation model - represents a chat conversation
model Conversation {
   id        String   @id @default(cuid())
   userId    String? // User ID if logged in (nullable for anonymous users)
   sessionId String? // Session identifier for anonymous users (nullable for logged-in users)
   agentId   String? // Agent ID if this is an agent conversation (nullable for basic LLM chats)
   title     String // Auto-generated from first message
   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt

   // Messages in this conversation
   messages Message[]

   // Relationship to User (optional)
   user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@index([userId])
   @@index([sessionId])
   @@index([agentId])
   @@index([updatedAt])
}

// Message model - represents a single message in a conversation
model Message {
   id             String   @id @default(cuid())
   conversationId String
   role           String // "user" | "assistant" | "system"
   content        String   @db.Text
   createdAt      DateTime @default(now())

   // File attachments
   attachments FileAttachment[]

   // Relationship
   conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

   @@index([conversationId])
   @@index([createdAt])
}

// FileAttachment model - represents file attachments in messages
model FileAttachment {
   id        String   @id @default(cuid())
   messageId String
   fileName  String
   fileType  String // MIME type (e.g., "image/png", "application/pdf")
   fileSize  Int // Size in bytes
   fileUrl   String? // URL if stored externally, or base64 data URL
   createdAt DateTime @default(now())

   // Relationship
   message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

   @@index([messageId])
}

model User {
   id            String         @id @default(cuid())
   name          String?
   email         String?        @unique
   emailVerified DateTime?
   image         String?
   role          String         @default("user")
   source        String         @default("EXTERNAL") // record origin; default EXTERNAL
   companyId     String? // Foreign key to Company
   createdAt     DateTime       @default(now())
   updatedAt     DateTime       @updatedAt
   accounts      Account[]
   company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
   sessions      Session[]
   conversations Conversation[] // User's conversations
   uploadedFiles UploadedFile[] // Files uploaded by this user
   escalationIncidents EscalationIncident[] // Guardrail escalations

   @@index([companyId])
   @@index([source])
}

model Account {
   id                String  @id @default(cuid())
   userId            String
   type              String
   provider          String
   providerAccountId String
   refresh_token     String?
   access_token      String?
   expires_at        Int?
   token_type        String?
   scope             String?
   id_token          String?
   session_state     String?
   user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@unique([provider, providerAccountId])
}

model Session {
   id           String   @id @default(cuid())
   sessionToken String   @unique
   userId       String
   expires      DateTime
   user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
   identifier String
   token      String
   expires    DateTime

   @@unique([identifier, token])
}

model Invitation {
   id         String    @id @default(cuid())
   email      String
   token      String    @unique
   status     String    @default("pending") // pending, accepted, expired, cancelled
   invitedBy  String
   expiresAt  DateTime
   createdAt  DateTime  @default(now())
   updatedAt  DateTime  @updatedAt
   acceptedAt DateTime?

   @@index([email])
   @@index([token])
   @@index([status])
}

model Company {
   id            String         @id @default(cuid())
   name          String         @unique
   billingEmail  String?
   createdAt     DateTime       @default(now())
   updatedAt     DateTime       @updatedAt
   users         User[] // Users in this company
   uploadedFiles UploadedFile[] // Files uploaded by users in this company
   escalationIncidents EscalationIncident[] // Guardrail escalations
}

// UploadedFile model - represents files uploaded to Azure Blob Storage for agents
model UploadedFile {
   id            String   @id @default(cuid())
   uploadedAt    DateTime @default(now()) @map("uploaded_at")
   uploadedBy    String   @map("uploaded_by") // User ID who uploaded the file
   blobUrl       String   @map("blob_url") // URL in blob pointing to this file
   fileName      String?  @map("file_name") // Original file name for better readability (nullable for existing records)
   companyId     String?  @map("company_id") // Company ID the user belongs to (nullable)
   extractedText String?  @map("extracted_text") @db.Text // Extracted text content for immediate access (before Azure AI Search indexing)

   // Relationships
   user    User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
   company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

   @@index([companyId])
   @@index([uploadedBy])
   @@index([uploadedAt])
}

// EscalationIncident model - tracks guardrail blocks that require escalation
model EscalationIncident {
   id         String   @id @default(uuid())
   createdAt  DateTime @default(now()) @map("created_at")
   userId     String   @map("user_id")
   chatId     String?  @map("chat_id") // Conversation/chat ID (nullable if not available)
   question   String   @db.Text // The user's question that triggered the guardrail
   companyId  String   @map("company_id")

   // Relationships
   user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
   company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

   @@index([userId])
   @@index([companyId])
   @@index([createdAt])
   @@index([chatId])
}
